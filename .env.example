# Copy this file to .env and fill in real values
# NEVER commit .env to git

# ── LLM Configuration ─────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Service Ports ─────────────────────────────────────────────────
GATEWAY_GRPC_PORT=50051
GATEWAY_HTTP_PORT=8080
AGENT_SERVICE_PORT=50052
SERVICE_A_PORT=8081
SERVICE_B_PORT=8082
SERVICE_C_PORT=8083
FAILURE_INJECTOR_PORT=8099

# ── Observability Backends ────────────────────────────────────────
JAEGER_ENDPOINT=localhost:4317
PROMETHEUS_ENDPOINT=localhost:9090
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# ── Rate Limiter Configuration ────────────────────────────────────
RATE_LIMIT_TOKENS_PER_SERVICE=10000
RATE_LIMIT_REFILL_RATE=1000

# ── Circuit Breaker Configuration ────────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=30
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2

# ── Incident Detection Thresholds ─────────────────────────────────
INCIDENT_ERROR_RATE_THRESHOLD=0.05
INCIDENT_LATENCY_P99_THRESHOLD_MS=2000
INCIDENT_DETECTION_WINDOW_SECONDS=60
